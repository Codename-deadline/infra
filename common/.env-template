DB_DB=deadlines
DB_PWD=__GEN_DB_PWD__
DB_USER=postgres

JWT_SECRET=__GEN_JWT_SECRET__
OTP_HASH_SECRET=__GEN_OTP_HASH_SECRET__

KAFKA_CLUSTER_ID=__GEN_KAFKA_CLUSTER_ID__
KAFKA_PORT=29092

GARAGE_RPC_SECRET=__GEN_GARAGE_RPC_SECRET__
GARAGE_ADMIN_TOKEN=__GEN_GARAGE_ADMIN_TOKEN__
GARAGE_METRICS_TOKEN=__GEN_GARAGE_METRICS_TOKEN__

S3_ENDPOINT=http://localhost:3900
S3_PUBLIC_ENDPOINT=${S3_ENDPOINT}

S3_REGION=garage
S3_BUCKET=__CONFIG.SETUP.garage.bucket__
S3_ACCESS_KEY=
S3_SECRET_KEY=

# API mappings
SPRING_DATASOURCE_PASSWORD=${DB_PWD}
SPRING_DATASOURCE_USERNAME=${DB_USER}
SPRING_SECURITY_JWT_SECRET=${JWT_SECRET}

TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
